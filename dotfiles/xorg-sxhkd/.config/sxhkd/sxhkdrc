# --------------------------------------------------------------
#                       VOLUME
# OpenBSD already implements these, at least on my Thinkpad -
# still works when "overloading" by notify-send
# (same for XF86 brightness keys - deleted thos from this config)
XF86AudioRaiseVolume
      notify-send -t 1000 "INC Vol"
XF86AudioLowerVolume
      notify-send -t 1000 "DEC Vol"
XF86AudioMute
      notify-send -t 1000 "toggle MUTE"

super + mod1 + Up
    vol=$(sndioctl -n output.level=+0.05 | awk '\{printf "%.0f", $1*100\}'); \
    notify-send -t 1500 -h int:value:"$vol" -h string:x-canonical-private-synchronous:volume "Volume: $vol%"

super + mod1 + Down
    vol=$(sndioctl -n output.level=-0.05 | awk '\{printf "%.0f", $1*100\}'); \
    notify-send -t 1500 -h int:value:"$vol" -h string:x-canonical-private-synchronous:volume "Volume: $vol%"

super + mod1 + Left
    if [ "$(sndioctl -n output.mute=!)" = 1 ]; \
      then dunstify -t 1500 -h int:value:-1 -h string:x-canonical-private-synchronous:volume "Volume: muted"; \
    else \
      vol=$(printf '%.0f' "$(echo "$(sndioctl -n output.level)*100" | bc)"); \
      notify-send -t 1500 -h int:value:"$vol" -h string:x-canonical-private-synchronous:volume "Volume unmuted: $vol%"; fi
# --------------------------------------------------------------
 

# --------------------------------------------------------------
#                       MISC
# kill all notifications
super + mod1 + k
      dunstctl close-all
# pop last notification from history
super + mod1 + h
      dunstctl history-pop
# lock screen
super + mod1 + l
      slock
# restart sxhkd
super + Escape
      pkill -x sxhkd && notify-send -t 2000 "sxhkd" "restarting sxhkd" && sleep 1 && sxhkd -t 3 &
# TODO
super + mod1 + Right
    xdotool search --name "Picture-in-Picture" key space
