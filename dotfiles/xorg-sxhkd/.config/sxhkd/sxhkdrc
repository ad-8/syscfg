# --------------------------------------------------------------
#                       SCREENSHOTS
# screenshot - everything
super + x; s; e
     p='/tmp/screenshot_openbsd_'"$(date '+%Y%m%d_%H%M%S')"'.png'; scrot "$p" && notify-send -t 4000 'screenshot everything' "$p"
# screenshot - select rectangle
super + x; s; s
     p='/tmp/screenshot_openbsd_'"$(date '+%Y%m%d_%H%M%S')"'.png'; scrot -s "$p" && notify-send -t 4000 'screenshot selection' "$p"
# screenshot - window
super + x; s; w
     p='/tmp/screenshot_openbsd_'"$(date '+%Y%m%d_%H%M%S')"'.png'; scrot -u "$p" && notify-send -t 4000 'screenshot window' "$p"
