// laserwave
// Themed via switch_theme.clj. Colors sourced from themes/laserwave/hyprland.lua
// (accent / black / red) + foot.theme background, matching hyprland's border convention.
// Merged per-property over config.kdl's layout block via `include`.
layout {
    background-color "#27212e"

    border {
        active-color   "#eb64b9"
        inactive-color "#222228"
        urgent-color   "#964c7b" // windows requesting attention
    }

    tab-indicator {
        active-color "#eb64b9"
    }
}

// overview/between-workspace void; global block merges (per-output backdrop does not)
overview {
    backdrop-color "#27212e"
}
