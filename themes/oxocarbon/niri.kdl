// oxocarbon
// Themed via switch_theme.clj. Colors sourced from themes/oxocarbon/hyprland.lua
// (accent / black / red) + foot.theme background, matching hyprland's border convention.
// Merged per-property over config.kdl's layout block via `include`.
layout {
    background-color "#161616"

    border {
        active-color   "#78a9ff"
        inactive-color "#262626"
        urgent-color   "#33b1ff" // windows requesting attention
    }

    tab-indicator {
        active-color "#78a9ff"
    }
}

// overview/between-workspace void; global block merges (per-output backdrop does not)
overview {
    backdrop-color "#161616"
}
