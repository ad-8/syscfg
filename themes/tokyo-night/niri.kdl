// tokyo-night
// Themed via switch_theme.clj. Colors sourced from themes/tokyo-night/hyprland.lua
// (accent / black / red) + foot.theme background, matching hyprland's border convention.
// Merged per-property over config.kdl's layout block via `include`.
layout {
    background-color "#1a1b26"

    border {
        active-color   "#7aa2f7"
        inactive-color "#414868"
        urgent-color   "#f7768e" // windows requesting attention
    }

    tab-indicator {
        active-color "#7aa2f7"
    }
}

// overview/between-workspace void; global block merges (per-output backdrop does not)
overview {
    backdrop-color "#1a1b26"
}
