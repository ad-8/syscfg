// wilmersdorf
// Themed via switch_theme.clj. Colors sourced from themes/wilmersdorf/hyprland.lua
// (accent / black / red) + foot.theme background, matching hyprland's border convention.
// Merged per-property over config.kdl's layout block via `include`.
layout {
    background-color "#282b33"

    border {
        active-color   "#819cd6"
        inactive-color "#222228"
        urgent-color   "#e1c1ee" // windows requesting attention
    }

    tab-indicator {
        active-color "#819cd6"
    }
}

// overview/between-workspace void; global block merges (per-output backdrop does not)
overview {
    backdrop-color "#282b33"
}
